# MongoDB (server-only — never expose in NEXT_PUBLIC_*)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=rostelecom_shop

# Legacy fallbacks (prefer MONGODB_* above)
# NEXT_PUBLIC_DB_URL=
# NEXT_PUBLIC_DB_NAME=

# YooKassa payment gateway (server-only)
YOOKASSA_SHOP_ID=your_shop_id
YOOKASSA_SECRET_KEY=your_secret_key

# Public site URL (used for payment redirect)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
PAYMENT_RETURN_URL=http://localhost:3000/payment-success

# JWT secret for auth routes
JWT_SECRET=change_me_in_production
